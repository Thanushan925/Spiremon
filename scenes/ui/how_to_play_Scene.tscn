[node name="Instructions" type="Label" parent="MarginContainer/CenterContainer/PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Choose a path on the map to progress through the run.

Battle:
Defeat an enemy to earn a move reward.

Heal:
Restore your HP.

Upgrade:
Improve a move or increase max HP.

Combat:
Use moves until you run out of energy or choose End Turn.
Some moves apply status effects.
Defend reduces the next enemy hit.

Reach the final boss at level 10 and win the run."
horizontal_alignment = 1
autowrap_mode = 3

